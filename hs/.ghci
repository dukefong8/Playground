:seti -XGHC2024
:seti -XDuplicateRecordFields
:seti -XNoFieldSelectors
:seti -XOverloadedLabels
:seti -XOverloadedRecordDot
:seti -XMagicHash
:seti -XPartialTypeSignatures

:set -Werror=deferred-out-of-scope-variables
:set -Werror=deferred-type-errors

:set -Wno-type-defaults
:set -Wno-unused-top-binds

:set -fdefer-type-errors
:set -fno-defer-typed-holes
:set -fplugin=Debug.Breakpoint

:set -outputdir .build
:set -isrc

:add App.TodoTest
:add Main
